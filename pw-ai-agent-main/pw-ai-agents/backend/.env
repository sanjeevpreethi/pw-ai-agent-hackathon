# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/pw_ai_agents
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# AI Model Configuration
AI_MODEL_ENDPOINT=https://api.openai.com/v1
AI_MODEL_KEY=your_api_key_here
AI_MODEL_NAME=gpt-4

# GrokAPI Configuration (xAI Grok LLM)
# Get your API key from: https://api.x.ai
GROK_ENABLED=true
GROK_API_KEY=REPLACE_WITH_YOUR_KEY_FROM_console.x.ai
GROK_MODEL=grok-3
GROK_ENDPOINT=https://api.x.ai/v1
GROK_MAX_TOKENS=2000
GROK_TEMPERATURE=0.7
GROK_USE_FOR_ENHANCEMENT=true

# Playwright MCP Configuration
MCP_SERVER_URL=http://localhost:8080
MCP_AUTH_TOKEN=your_mcp_token

# Jira Configuration (Phase 2)
JIRA_URL=https://your-jira-instance.atlassian.net
JIRA_API_TOKEN=your_jira_token
JIRA_USERNAME=your_jira_email@example.com

# Test Configuration
TEST_TIMEOUT_MS=60000
TEST_RETRY_ATTEMPTS=3
MAX_PARALLEL_WORKERS=4
BROWSER_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key_32_chars_min

# Storage
ARTIFACT_STORAGE_PATH=/var/pw-ai-agents/artifacts
TEST_SCRIPT_OUTPUT_PATH=/var/pw-ai-agents/scripts

# Feature Flags
ENABLE_JIRA_INTEGRATION=false
ENABLE_AUTO_HEALING=false
ENABLE_TEST_DATA_GENERATOR=false
